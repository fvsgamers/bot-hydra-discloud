{
  "name": "bot-hydra-discloud",
  "description": "Bot de recrutamento Hydra - plano Gold Discloud",
  "start": "node index.js",
  "build": "npm install",
  "env": {
    "TOKEN": "SEU_TOKEN_DO_BOT",
